---
import Container from '@components/common/Container.astro';
import { catalog } from '@data/catalog';

const themeCount = catalog.length;
---

<section class="relative py-20 overflow-hidden">
  <div
    class="absolute inset-0
    bg-[radial-gradient(circle_at_50%_50%,rgba(23,147,209,0.05),transparent_70%)]"
    aria-hidden="true">
  </div>

  <Container>
    <div class="max-w-4xl py-6 mx-auto text-center relative z-10">
      <h1 class="text-white text-8xl font-black uppercase leading-none">
        Grub Theme
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-arch to-arch/40">
          Collection
        </span>
      </h1>

      <p
        class="mt-4 text-arch text-xl font-bold uppercase tracking-widest
        [text-shadow:0_0_10px_rgba(23,147,209,0.5),0_0_20px_rgba(23,147,209,0.2)]">
        {themeCount} Custom Linux Themes
      </p>
    </div>
  </Container>
</section>
