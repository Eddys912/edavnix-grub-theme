---
import ChevronLeft from '@icons/ui/ChevronLeft.astro';
import ChevronRight from '@icons/ui/ChevronRight.astro';

interface Props {
  currentPage: number;
  totalPages: number;
  buildUrl: (page: number) => string;
  class?: string;
}

const { currentPage, totalPages, buildUrl, class: className } = Astro.props;

type PageItem = number | '...';

const getPageItems = (current: number, total: number): PageItem[] => {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);

  const items = new Set<number>();

  items.add(1);
  items.add(total);

  items.add(Math.max(2, current - 1));
  items.add(Math.min(total - 1, current + 1));
  items.add(current);

  const sorted = [...items].sort((a, b) => a - b);

  const result: PageItem[] = [];
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && sorted[i] - sorted[i - 1] > 1) result.push('...');
    result.push(sorted[i]);
  }

  return result;
};

const pages = getPageItems(currentPage, totalPages);

const prevUrl = currentPage > 1 ? buildUrl(currentPage - 1) : undefined;
const nextUrl = currentPage < totalPages ? buildUrl(currentPage + 1) : undefined;

const baseItem =
  'size-10 flex items-center justify-center text-sm font-bold border rounded transition-all';
const activeItem = 'bg-arch text-dark border-arch';
const idleItem = 'text-slate-400 border-white/10 hover:border-arch hover:text-arch';
const arrowActive = 'text-arch border-arch/20 hover:bg-arch hover:text-dark';
const arrowDisabled = 'text-slate-700 border-white/5 pointer-events-none select-none';
---

<nav
  class:list={['flex items-center justify-center gap-2', className]}
  aria-label="Pagination"
  role="navigation">
  <a
    href={prevUrl ?? '#'}
    aria-label="Previous page"
    aria-disabled={!prevUrl}
    class:list={[baseItem, prevUrl ? arrowActive : arrowDisabled]}>
    <ChevronLeft class="size-4" />
  </a>

  {
    pages.map((p) =>
      p === '...' ? (
        <span class="size-10 flex items-center justify-center text-slate-600 select-none">
          &hellip;
        </span>
      ) : (
        <a
          href={buildUrl(p)}
          aria-label={`Page ${p}`}
          aria-current={p === currentPage ? 'page' : undefined}
          class:list={[baseItem, p === currentPage ? activeItem : idleItem]}>
          {p}
        </a>
      )
    )
  }

  <a
    href={nextUrl ?? '#'}
    aria-label="Next page"
    aria-disabled={!nextUrl}
    class:list={[baseItem, nextUrl ? arrowActive : arrowDisabled]}>
    <ChevronRight class="size-4" />
  </a>
</nav>
